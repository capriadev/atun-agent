{
  "name": "atun-agent",
  "displayName": "Atun Agent",
  "description": "Native VS Code chat agent",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onChatParticipant:atun-agent.atun",
    "onView:atunAgent.controls",
    "onCommand:atun-agent.openChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "atun-agent.openChat",
        "title": "Atun Agent: Open Chat"
      },
      {
        "command": "atun-agent.focusSidebar",
        "title": "Atun Agent: Focus Sidebar"
      },
      {
        "command": "atun-agent.setAccessMode",
        "title": "Atun Agent: Set Access Mode"
      },
      {
        "command": "atun-agent.toggleThinkingMode",
        "title": "Atun Agent: Toggle Thinking"
      },
      {
        "command": "atun-agent.setModelOverride",
        "title": "Atun Agent: Set Model Override"
      },
      {
        "command": "atun-agent.stopResponse",
        "title": "Atun Agent: Stop Response"
      },
      {
        "command": "atun-agent.openSkillsCommand",
        "title": "Atun Agent: Open /skills"
      },
      {
        "command": "atun-agent.showHashHint",
        "title": "Atun Agent: Show # Hint"
      }
    ],
    "keybindings": [
      {
        "command": "atun-agent.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus || sideBarFocus || panelFocus || terminalFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "atunAgentSidebar",
          "title": "Atun Agent",
          "icon": "assets/icons/logo/atunagent.svg"
        }
      ]
    },
    "views": {
      "atunAgentSidebar": [
        {
          "id": "atunAgent.controls",
          "name": "Atun Agent"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "atun-agent.atun",
        "name": "atun",
        "fullName": "Atun Agent",
        "description": "Editor-integrated coding agent",
        "isSticky": true,
        "commands": [
          {
            "name": "skills",
            "description": "List available skills"
          },
          {
            "name": "access",
            "description": "Set access mode (isolated/full)"
          },
          {
            "name": "thinking",
            "description": "Toggle reasoning mode"
          }
        ]
      }
    ],
    "configuration": {
      "title": "Atun Agent",
      "properties": {
        "atunAgent.accessMode": {
          "type": "string",
          "enum": [
            "isolated",
            "full"
          ],
          "default": "isolated",
          "description": "Default access mode used by Atun Agent."
        },
        "atunAgent.preferSecondarySideBar": {
          "type": "boolean",
          "default": true,
          "description": "Try to focus Atun Agent in secondary side bar when possible."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.32.0",
    "esbuild": "^0.25.8",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
