{
  "name": "atun-agent",
  "publisher": "capriadev",
  "displayName": "Atun Agent",
  "description": "Sidebar AI chat agent for coding workflows with files, skills, selectors and token estimation",
  "version": "1.1.2",
  "author": {
    "name": "capriadev",
    "url": "https://github.com/capriadev"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/capriadev/atun-agent.git"
  },
  "homepage": "https://github.com/capriadev/atun-agent#readme",
  "bugs": {
    "url": "https://github.com/capriadev/atun-agent/issues"
  },
  "keywords": [
    "agent",
    "chat",
    "ai",
    "vscode",
    "llm"
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onView:atunAgent.chatView",
    "onCommand:atun-agent.openChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "atun-agent.openChat",
        "title": "Atun Agent: Open Chat"
      },
      {
        "command": "atun-agent.focusSidebar",
        "title": "Atun Agent: Focus Sidebar"
      },
      {
        "command": "atun-agent.stopResponse",
        "title": "Atun Agent: Stop Response"
      }
    ],
    "keybindings": [
      {
        "command": "atun-agent.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus || sideBarFocus || panelFocus || terminalFocus"
      },
      {
        "command": "atun-agent.openChat",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus || sideBarFocus || panelFocus || terminalFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "atunAgentSidebar",
          "title": "Atun Agent",
          "icon": "assets/icons/ghost-chat.svg"
        }
      ]
    },
    "views": {
      "atunAgentSidebar": [
        {
          "id": "atunAgent.chatView",
          "name": "Atun Agent",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Atun Agent",
      "properties": {
        "atunAgent.accessMode": {
          "type": "string",
          "enum": [
            "isolated",
            "full"
          ],
          "default": "isolated",
          "description": "Default access mode used by Atun Agent."
        },
        "atunAgent.preferSecondarySideBar": {
          "type": "boolean",
          "default": true,
          "description": "Try to focus Atun Agent in secondary side bar when possible."
        },
        "atunAgent.autoRevealOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Auto-open Atun Agent sidebar on first activation."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.32.0",
    "esbuild": "^0.25.8",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
