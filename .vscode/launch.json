{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/atunagent"
      ],
      "outFiles": [
        "${workspaceFolder}/atunagent/dist/**/*.js"
      ],
      "preLaunchTask": "npm: watch"
    }
  ]
}
